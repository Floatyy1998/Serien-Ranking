{
  "name": "tv-rank",
  "version": "1.1.0",
  "description": "TV-Rank - Serien, Film & Manga Tracker",
  "author": "Konrad Dinges",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"node scripts/electron-dev.cjs\"",
    "bump-version": "node scripts/bump-sw-version.js",
    "build": "tsc && vite build && firebase deploy",
    "build:local": "tsc && vite build",
    "build:electron": "tsc && vite build && electron-builder --win && node scripts/deploy-electron.cjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node --max-old-space-size=8192 node_modules/vitest/vitest.mjs run --coverage",
    "test:related": "vitest related --run --passWithNoTests",
    "test:changed": "vitest run --changed --passWithNoTests",
    "preview": "vite preview",
    "copy": "for %D in (F:\\Programme\\SerienFlo\\src F:\\Programme\\SerienDesiree\\src F:\\Programme\\SerienMick\\src) do xcopy F:\\Programme\\Serien\\src %D /E /H /C /I /Y ",
    "deploy_all": "npm run build && cd F:\\Programme\\SerienFlo && npm run build && cd F:\\Programme\\SerienDesiree && npm run build && cd F:\\Programme\\SerienMick && npm run build",
    "copy_and_deploy": "npm run copy && npm run deploy_all",
    "generate-sitemap": "node generate-sitemap.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "electron-updater": "^6.8.3",
    "firebase": "^12.8.0",
    "framer-motion": "^12.29.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.1",
    "rcedit": "^5.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  }
}
