# iOS-Build ohne Mac: Zertifikat + Profil kommen per App-Store-Connect-API
# (Admin-Key), signiert wird manuell mit Apple Distribution, Upload zu
# TestFlight via pilot. Laeuft auf dem GitHub-macOS-Runner (fastlane vorinstalliert).

default_platform(:ios)

require_relative "widget_target"

APP_ID = "de.tvrank.app"
WIDGET_ID = "de.tvrank.app.TVRankWidget"

platform :ios do
  desc "Build + Upload zu TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APPSTORE_KEY_ID"),
      issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
      key_filepath: ENV.fetch("APPSTORE_P8_PATH")
    )

    setup_ci

    # Widget-Target zur Build-Zeit einhängen + lokales Bridge-Plugin registrieren
    add_widget_target!("ios/App/App.xcodeproj")
    register_widget_bridge_plugin!("ios/App/App/capacitor.config.json")

    # Widget-Bundle-ID im Portal anlegen (einmalig, idempotent)
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("APPSTORE_KEY_ID"),
      issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
      filepath: ENV.fetch("APPSTORE_P8_PATH")
    )
    if Spaceship::ConnectAPI::BundleId.all(filter: { identifier: WIDGET_ID })
         .none? { |b| b.identifier == WIDGET_ID }
      Spaceship::ConnectAPI::BundleId.create(
        name: "TVRank Widget",
        identifier: WIDGET_ID,
        platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS
      )
    end

    # Die CI-Keychain ist fluechtig, cert() legt daher pro Lauf ein neues
    # Distribution-Zertifikat an — alte vorher loeschen, sonst ist Apples
    # Team-Limit (2) nach zwei Läufen voll. Profile werden unten neu erzeugt.
    Spaceship::ConnectAPI::Certificate
      .all(filter: { certificateType: "DISTRIBUTION" })
      .each { |c| c.delete! rescue nil }

    cert(
      api_key: api_key,
      development: false,
      generate_apple_certs: true,
      output_path: "build/certs",
      keychain_path: File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db"),
      keychain_password: ""
    )

    sigh(
      api_key: api_key,
      app_identifier: APP_ID,
      force: true,
      output_path: "build/certs"
    )
    app_profile_name = lane_context[SharedValues::SIGH_NAME]

    sigh(
      api_key: api_key,
      app_identifier: WIDGET_ID,
      force: true,
      output_path: "build/certs"
    )
    widget_profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: app_profile_name,
      bundle_identifier: APP_ID,
      targets: ["App"]
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: widget_profile_name,
      bundle_identifier: WIDGET_ID,
      targets: ["TVRankWidget"]
    )

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      output_directory: "build/ipa",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_ID => app_profile_name,
          WIDGET_ID => widget_profile_name,
        },
      },
      xcargs: "MARKETING_VERSION=1.0 CURRENT_PROJECT_VERSION=#{ENV.fetch('BUILD_NUMBER', '1')}"
    )

    pilot(
      api_key: api_key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true
    )
  end
end
